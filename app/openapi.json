              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Audit"
      }
    },
    "/v1/devices": {
      "get": {
        "description": "`band` (the canonical FULL_PROXY_SOURCES entries) rides along so\nthe UI can gate a NEW override on a band address with a confirm\nBEFORE posting — DEC-4 covers adds, not just flips on listed rows.",
        "operationId": "get_devices_v1_devices_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Get Devices V1 Devices Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Devices"
      },
      "post": {
        "operationId": "post_device_v1_devices_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Post Device V1 Devices Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Post Device"
      }
    },
    "/v1/devices/{device_id}": {
      "delete": {
        "description": "NOTE rides a query parameter (DELETE bodies are non-portable) and\nlands on the removal's audit entry — every mutation carries requester\nIP + optional note.",
