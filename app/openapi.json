        "parameters": [
          {
            "in": "path",
            "name": "device_id",
            "required": true,
            "schema": {
              "title": "Device Id",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "note",
            "required": false,
            "schema": {
              "default": "",
