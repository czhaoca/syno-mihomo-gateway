# Secrets & user configuration — NEVER commit (see CLAUDE.md)
.env
.env.*
!.env.example

# Rendered/generated runtime config (built from config.template.yaml at container start)
config/config.yaml

# Real subscription (holds provider token). Ship subscription.txt.example instead.
config/subscription.txt

# Auto-update orchestrator runtime state & logs
logs/
*.log
.update_state

# Persistent runtime state. The canonical location is a SIBLING of the repo
# (../syno-mihomo-gateway-data); ignore any stray copy that lands inside the tree
# from a manual misrun or a test that resolves GATEWAY_DATA_DIR under the repo.
syno-mihomo-gateway-data/

# Release artifacts (scripts/package.sh output)
dist/

# Editor / OS noise
.DS_Store
.ruff_cache/
__pycache__/
