# ==========================================
# USER CONFIGURATION
#   cp .env.example .env  &&  chmod 600 .env   (it holds secrets; .env is gitignored)
# ==========================================

# --- Network Settings ---
# Your main router's IP address (Gateway). Example: 192.168.1.1
ROUTER_IP=192.168.1.1
# The subnet of your home network. Example: 192.168.1.0/24
SUBNET_CIDR=192.168.1.0/24
# Static IP assigned to Mihomo on the macvlan (must be unused on the LAN).
MIHOMO_IP=192.168.1.100

# --- Ports ---
# Web dashboard (MetaCubeXD), published on the NAS host IP.
WEB_UI_PORT=8080
# Mihomo RESTful controller port. Browser connects to MIHOMO_IP:CONTROLLER_PORT.
CONTROLLER_PORT=9090
# Controller auth secret. Leave EMPTY for no auth. Must NOT contain a '|' character.
CONTROLLER_SECRET=

# --- DNS (comma-separated lists; injected into config.template.yaml) ---
# Bootstrap resolvers used to resolve the nameserver/fallback hostnames.
DNS_DEFAULT_NAMESERVER=114.114.114.114,223.5.5.5
# Domestic resolvers.
DNS_NAMESERVER=114.114.114.114,223.5.5.5
# Overseas / anti-pollution resolvers.
DNS_FALLBACK=8.8.8.8,8.8.4.4

# --- Container Images ---
# Point these at your Alibaba ACR mirror (must match docker-china-sync naming:
#   ${DOCKER_REGISTRY}/${ACR_NAMESPACE}/<image:tag>).
# IMPORTANT: the auto-updater maps each UPDATE_IMAGES entry to a deploy target by an
# EXACT match against these three vars (MIHOMO_IMAGE / METACUBEXD_IMAGE / CF_IMAGE).
# On the China/ACR path set these three to the ACR refs and let UPDATE_IMAGES inherit
# them (below) — do NOT hand-set UPDATE_IMAGES to refs that differ from these, or the
# pulled image is cached but never deployed (the updater logs a WARN).
# Default Global: metacubex/mihomo:latest
MIHOMO_IMAGE=metacubex/mihomo:latest
# Default Global: ghcr.io/metacubex/metacubexd:latest
METACUBEXD_IMAGE=ghcr.io/metacubex/metacubexd:latest
# cloudflared image (ACR-mirrored). Defined here so UPDATE_IMAGES can reference it.
CF_IMAGE=

# --- Alibaba ACR (China mirror — PULL side) ---
# Registry host, e.g. registry.cn-shenzhen.aliyuncs.com
DOCKER_REGISTRY=
# ACR username (reused by setup_network.sh interactive login and the orchestrator).
DOCKER_USERNAME=
# ACR password / access token — SECRET. Keep .env gitignored + chmod 600.
ACR_PASSWORD=
# ACR namespace (the ${ALIYUN_NAME_SPACE} from docker-china-sync), e.g. myns
ACR_NAMESPACE=

# --- Auto-Update Orchestrator (scripts/auto_update.sh, run by DSM Task Scheduler) ---
# Master kill-switch. Set to "false" to disable all auto-updates.
UPDATE_ENABLED=true
# Images the job checks/pulls. Space-separated. Recommended: leave this inheriting the
# three image vars above (so the deploy mapping always matches). Add extra refs (e.g. to
# warm the local cache for other containers) only if you understand they won't auto-deploy.
# Keep the set aligned with docker-china-sync/images.txt.
UPDATE_IMAGES="${MIHOMO_IMAGE} ${METACUBEXD_IMAGE} ${CF_IMAGE}"
# Cron expression — source-of-truth for the DSM task / fallback crontab.
# MUST be quoted (contains spaces and '*' which the shell would otherwise glob).
UPDATE_SCHEDULE="0 9 * * *"
# Timezone the schedule runs in (the script exports this as TZ).
UPDATE_TZ=Asia/Shanghai
# Guard against the amd64-only mirror landing on an ARM NAS. amd64 | arm64
EXPECTED_ARCH=amd64

# --- cloudflared (EXTERNAL container — blue-green by name, token preserved) ---
# (CF_IMAGE is defined in the Container Images section above.)
# Canonical name of the running cloudflared container on the NAS.
CF_CONTAINER_NAME=cloudflared
# Tunnel token OVERRIDE. Leave blank to reuse the token from the running container
# (preferred — preserves the key). Required only if no cloudflared container exists yet.
CF_TUNNEL_TOKEN=
# Seconds to wait for the new connector to report "connected" before cutover.
CF_HEALTH_TIMEOUT=60

# --- Reporting ---
# Synology DSM push notification is used automatically (synodsmnotify) when available.
# Optional fallback webhook (Bark / Gotify / Slack-compatible) if synodsmnotify is absent.
NOTIFY_WEBHOOK_URL=
# Notify even when nothing changed (0 = quiet on no-op runs).
NOTIFY_ON_NOCHANGE=0
# Rotating log file for orchestrator runs + how many rotations to keep.
UPDATE_LOG=./logs/auto-update.log
LOG_KEEP=7

# --- System ---
TZ=Asia/Shanghai
