# ==========================================
# USER CONFIGURATION
#   cp .env.example .env  &&  chmod 600 .env   (it holds secrets; .env is gitignored)
# ==========================================

# Installer UI language: en or zh.
INSTALLER_LANG=en

# --- Network Settings ---
# Your main router's IP address (Gateway). Example: 192.168.1.1
ROUTER_IP=192.168.1.1
# The subnet of your home network. Example: 192.168.1.0/24
SUBNET_CIDR=192.168.1.0/24
# Static IP assigned to Mihomo on the macvlan (must be unused on the LAN).
MIHOMO_IP=192.168.1.100
# Macvlan parent = the LAN-facing NIC. The installer fills this from the interface
# scan; leave blank to auto-detect (the boot-up self-heal task auto-detects too).
PARENT_INTERFACE=
# L2 network driver: macvlan (default) or ipvlan. KEEP macvlan for the gateway
# role: a macvlan child IS reachable from LAN peers even on an Open vSwitch
# parent (ovs_eth0) - verified empirically; OVS is not a cause of dashboard
# timeouts. ipvlan demuxes by destination IP and will NOT route LAN clients
# through the proxy, so it is only a dashboard-reachability escape hatch the
# installer offers on some OVS setups - never a fix for the forwarding role.
TPROXY_DRIVER=macvlan

# --- Mihomo TUN (transparent gateway) ---
# ON by default - this is a gateway. LAN devices point their gateway + DNS at MIHOMO_IP
# and mihomo routes them to the internet through the airport. mihomo uses the `system`
# TUN stack, which (unlike `mixed`/`gvisor`) does NOT hijack the controller reply path,
# so the dashboard backend at MIHOMO_IP:CONTROLLER_PORT stays reachable (mihomo #1493).
# Set false to run as a plain proxy (clients use MIHOMO_IP:7890 explicitly instead).
TUN_ENABLE=true
# Only consulted when TUN_ENABLE=true: optional Linux TCP redirect optimization that
# needs a compatible nftables kernel/userspace pair older Synology kernels lack.
# Set true only after the installer compatibility probe succeeds.
TUN_AUTO_REDIRECT=false

# --- Ports ---
# Web dashboard (MetaCubeXD), published on the NAS host IP.
WEB_UI_PORT=8080
# Mihomo RESTful controller port. Browser connects to MIHOMO_IP:CONTROLLER_PORT.
CONTROLLER_PORT=9090
# Controller auth secret. Leave EMPTY for no auth. Must NOT contain a '|' character.
CONTROLLER_SECRET=

# --- DNS (comma-separated lists; injected into config.template.yaml) ---
# Bootstrap resolvers used to resolve the nameserver/fallback hostnames.
DNS_DEFAULT_NAMESERVER=1.1.1.1
# Domestic resolvers.
DNS_NAMESERVER=1.1.1.1
# Overseas / anti-pollution resolvers.
DNS_FALLBACK=1.1.1.1

# --- Container Images ---
# REGISTRY_MODE selects where images are pulled from:
#   acr    = your private Alibaba ACR mirror (default; required in mainland China
#            where Docker Hub / ghcr.io are blocked)
#   docker = upstream public registries (Docker Hub / ghcr.io); only works on a NAS
#            with unfiltered internet access
# The guided installer (install.sh) sets this and DERIVES the image refs below from
# DOCKER_REGISTRY + ACR_NAMESPACE + the *_TAG values, so you enter the registry and
# namespace once instead of per image.
REGISTRY_MODE=acr

# Image tag pulled for each component (used to derive the refs below).
MIHOMO_TAG=latest
METACUBEXD_TAG=latest
CF_TAG=latest

# Fully-qualified refs actually consumed by docker-compose.yml. It is wired with
# ${VAR:?} so an UNSET ref FAILS the deploy loudly instead of pulling something
# unexpected. The installer rewrites these from REGISTRY_MODE; you do not normally
# edit them by hand.
# IMPORTANT: the auto-updater maps each UPDATE_IMAGES entry to a deploy target by an
# EXACT match against these three vars (MIHOMO_IMAGE / METACUBEXD_IMAGE / CF_IMAGE),
# so keep UPDATE_IMAGES inheriting them (below) rather than hand-setting other refs.
MIHOMO_IMAGE=registry.cn-shenzhen.aliyuncs.com/your-namespace/mihomo:latest
METACUBEXD_IMAGE=registry.cn-shenzhen.aliyuncs.com/your-namespace/metacubexd:latest
# cloudflared image (optional/external). Leave blank unless you run a tunnel.
CF_IMAGE=

# --- Private registry / Alibaba ACR (used when REGISTRY_MODE=acr) ---
# Registry host, e.g. registry.cn-shenzhen.aliyuncs.com
DOCKER_REGISTRY=
# Registry login username (used by the installer and the auto-update orchestrator).
DOCKER_USERNAME=
# Registry password / access token — SECRET. Keep .env gitignored + chmod 600.
# Least privilege: use a dedicated PULL-ONLY ACR sub/RAM account here, distinct
# from the push account your mirror-sync pipeline uses - the updater only pulls.
ACR_PASSWORD=
# Registry namespace your images live under, e.g. myns
ACR_NAMESPACE=

# --- Auto-Update Orchestrator (scripts/auto_update.sh, run by DSM Task Scheduler) ---
# Master kill-switch. Set to "false" to disable all auto-updates.
UPDATE_ENABLED=true
# Images the job checks/pulls. Space-separated. Recommended: leave this inheriting the
# three image vars above (so the deploy mapping always matches). Add extra refs (e.g. to
# warm the local cache for other containers) only if you understand they won't auto-deploy.
# Keep this inheriting the three image vars above unless you know exactly why not.
UPDATE_IMAGES="${MIHOMO_IMAGE} ${METACUBEXD_IMAGE} ${CF_IMAGE}"

# Generic targets: OTHER running containers auto-update too once enrolled via
# `gateway.sh update --enable <name>` (managed list under the data dir, not here).
# Optional glob denylist - matching container names are never auto-updated:
#UPDATE_DENY_CONTAINERS="critical-* my-database"
# Cron expression — source-of-truth for the DSM task / fallback crontab.
# MUST be quoted (contains spaces and '*' which the shell would otherwise glob).
UPDATE_SCHEDULE="0 2 * * *"
# Timezone used inside the updater for log timestamps. DSM Task Scheduler fires
# according to the NAS timezone under Control Panel > Regional Options.
UPDATE_TZ=Asia/Shanghai
# DSM boot/scheduled tasks may race Container Manager startup. Wait this many
# seconds, checking at this interval, before reporting a preflight failure.
DOCKER_READY_TIMEOUT=120
DOCKER_READY_INTERVAL=5
# Guard against pulling an image built for the wrong CPU (e.g. the amd64-only
# default mirror landing on an ARM box). amd64 | arm64 | arm (32-bit, e.g. an
# armv7 Raspberry Pi)
EXPECTED_ARCH=amd64

# --- cloudflared (EXTERNAL container — blue-green by name, token preserved) ---
# (CF_IMAGE is defined in the Container Images section above.)
# Canonical name of the running cloudflared container on the NAS.
CF_CONTAINER_NAME=cloudflared
# Tunnel token OVERRIDE. Leave blank to reuse the token from the running container
# (preferred — preserves the key). Required only if no cloudflared container exists yet.
CF_TUNNEL_TOKEN=
# Seconds to wait for the new connector to report "connected" before cutover.
CF_HEALTH_TIMEOUT=60

# --- Reporting ---
# The reliable default alert path is DSM Task Scheduler's "send run details by
# email" (driven by exit codes). This optional webhook (Bark / Gotify /
# Slack-compatible JSON POST) is the rich opt-in channel: it fires whenever
# configured - failure AND success - independent of the best-effort DSM push
# (synodsmnotify is unverifiable on DSM 7 and never gates the webhook).
NOTIFY_WEBHOOK_URL=
# Notify even when nothing changed (0 = quiet on no-op runs).
NOTIFY_ON_NOCHANGE=0
# Rotating log file for orchestrator runs + how many rotations to keep.
UPDATE_LOG=./logs/auto-update.log
LOG_KEEP=7

# --- Raspberry Pi bare-metal "lite" mode (consumed by the Pi installer once the
# raspberry-pi-port epic lands; harmless and unused on DSM) ---
# Mirror prefix applied to GitHub download URLs (mihomo binary, dashboard build,
# geodata) on networks where github.com is unreachable. Empty = direct GitHub.
#GH_MIRROR=
# Pin the mihomo release tag for lite-mode installs/updates. Empty = latest.
#MIHOMO_VERSION=
# Optional integrity anchor for a PINNED release (upstream publishes no
# checksums): when set, the downloaded archive must match this sha256 before
# anything is installed - useful when downloads ride a third-party gh-proxy.
#MIHOMO_SHA256=
# Folder mihomo serves the MetaCubeXD static dashboard from (rendered into
# config.yaml's external-ui ONLY when set; the DSM compose path leaves it unset).
#EXTERNAL_UI_DIR=

# --- System ---
TZ=Asia/Shanghai
